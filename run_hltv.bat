@echo off
cls
chcp 65001 > nul

title Скрипт HLTV [Zombie Plague 5.0]
echo =======================================================
echo          Запуск HLTV для записи демок...
echo =======================================================

:: НАСТРОЙКА IP И ПОРТА (Впиши сюда IP своего сервера!)
set SERVER_IP=127.0.0.1:27015

:loop
echo [%time:~0,8%] Запуск hltv.exe и подключение к %SERVER_IP%...

:: ЧИСТЫЙ ЗАПУСК: только конфиг и коннект. Никаких лишних команд!
hltv.exe +exec hltv.cfg +connect %SERVER_IP%

echo =======================================================
echo ВНИМАНИЕ: HLTV отключился! Перезапуск через 5 секунд...
echo =======================================================
ping -n 5 127.0.0.1 > nul
goto loop
